# Required
IRODS_PATH=/sodarZone/projects/<project-id>/sample_data/<study-id>/MiscFiles/seapiper
DAVRODS_SERVER=sodar.bihealth.org
IRODS_TOKEN=replace-me

# JSON array; keep it on one line for shell compatibility
datasets=[{"name":"Example data set","archive":"DE_pipeline.tar.gz","config":"DE_config.yaml","format":"rseasnap"}]

# Optional
TITLE=SeaPiper example project
IMAGE=ghcr.io/bihealth/seapiper:0.6.7
HOST_PORT=8080
